DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# GitHub OAuth App credentials (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Backend callback URL registered in GitHub OAuth App (web portal flow)
GITHUB_REDIRECT_URI=https://your-backend.vercel.app/auth/github/callback

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_strong_jwt_secret

# Web portal URL (for CORS allow-list and post-login redirect)
FRONTEND_URL=https://your-portal.vercel.app
